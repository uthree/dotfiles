// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette
{
    "agent": {
        "dock": "right",
        "favorite_models": [],
        "model_parameters": []
    },
    "cli_default_open_behavior": "existing_window",
    "show_edit_predictions": true,
    "collaboration_panel": {
        "dock": "left",
    },
    "git_panel": {
        "dock": "left",
    },
    "edit_predictions": {
        "allow_data_collection": "no",
        "provider": "none",
    },
    "search": {
        "button": true,
    },
    "diagnostics": {
        "button": true,
    },
    "status_bar": {
        "cursor_position_button": true,
        "active_language_button": true,
    },
    "title_bar": {
        "show_branch_status_icon": true,
        "show_menus": false,
    },
    "preview_tabs": {
        "enable_preview_from_file_finder": false,
    },
    "tabs": {
        "file_icons": true,
        "git_status": true,
    },
    "tab_bar": {
        "show_nav_history_buttons": false,
        "show": true,
    },
    "tab_size": 4,
    "agent_servers": {},
    "confirm_quit": true,
    "show_signature_help_after_edits": false,
    "show_completion_documentation": false,
    "show_completions_on_input": true,
    "outline_panel": {
        "dock": "left",
        "default_width": 300.0,
    },
    "project_panel": {
        "default_width": 240.0,
        "dock": "left",
        "button": true,
        "file_icons": true,
    },
    "agent_buffer_font_size": 14.0,
    "buffer_font_weight": 400.0,
    "ui_font_weight": 400.0,
    "vim_mode": false,
    "icon_theme": {
        "mode": "dark",
        "light": "Zed (Default)",
        "dark": "Zed (Default)",
    },
    "buffer_font_family": "HackGen35 Console NF",
    "ui_font_family": "HackGen35 Console NF",
    "terminal": {
        "cursor_shape": "bar",
        "button": true,
        "dock": "bottom",
        "font_family": "HackGen35 Console NF",
        "font_size": 14.0,
    },
    "ui_font_size": 14,
    "buffer_font_size": 14.0,
    "theme": {
        "mode": "dark",
        "light": "One Light",
        "dark": "One Dark Pro",
    },
    "auto_update": true,
}
